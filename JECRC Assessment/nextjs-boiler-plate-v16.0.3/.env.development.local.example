NEXT_PUBLIC_DISABLE_AUTH=true

# Copy this file to ".env.development.local" and pick ONE backend target.
# Used only by `npm run dev`. Production builds use .env.production.

# --- LOCAL backend (needs .NET 10 SDK + local PostgreSQL running) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:5056
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:5056/graphql

# --- PRODUCTION backend (GCP VM) ---
# NEXT_PUBLIC_API_BASE_URL=http://35.202.189.169
# NEXT_PUBLIC_GRAPHQL_URL=http://35.202.189.169/graphql
